{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":disableDependencyDashboard"],
  "schedule": ["every weekend"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "groupName": "frontend",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom",
        "@vitejs/plugin-react",
        "babel-plugin-react-compiler",
        "@tanstack/**",
        "@radix-ui/**",
        "class-variance-authority",
        "lucide-react",
        "clsx",
        "tailwindcss",
        "@tailwindcss/**",
        "tailwind-merge",
        "tw-animate-css"
      ]
    },
    {
      "groupName": "webextension",
      "matchPackageNames": [
        "web-ext",
        "webextension-polyfill",
        "@types/webextension-polyfill",
        "@types/chrome"
      ]
    },
    {
      "groupName": "tooling",
      "matchPackageNames": [
        "vite",
        "vite-**",
        "@vitejs/**",
        "!@vitejs/plugin-react",
        "typescript",
        "@biomejs/**",
        "husky",
        "vitest",
        "@types/**",
        "!@types/react",
        "!@types/react-dom",
        "!@types/chrome",
        "!@types/webextension-polyfill"
      ]
    }
  ],
  "postUpdateOptions": ["pnpmDedupe"]
}

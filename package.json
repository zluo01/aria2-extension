{
  "name": "aria2-extension",
  "displayName": "Aria2 Integration Extension",
  "version": "0.7.0",
  "private": true,
  "scripts": {
    "analyze": "npx vite-bundle-visualizer",
    "build": "tsc && vite build",
    "build:chrome": "tsc && TARGET=CHROME vite build",
    "complete": "pnpm run build && pnpm run package",
    "complete:chrome": "pnpm run build:chrome && pnpm run package",
    "dev": "vite build --mode dev && web-ext run --source-dir ./build/",
    "dev:chrome": "TARGET=CHROME vite build --mode dev && web-ext run --source-dir ./build/ -t chromium",
    "lint": "biome check --write .",
    "package": "web-ext build --config=webext.config.cjs",
    "prepare": "husky",
    "test": "vitest run",
    "type-check": "tsc --pretty --noEmit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.5",
    "@radix-ui/react-label": "2.1.10",
    "@radix-ui/react-progress": "1.1.10",
    "@radix-ui/react-select": "2.3.1",
    "@radix-ui/react-separator": "1.1.10",
    "@radix-ui/react-slot": "1.3.0",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.16",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "1.168.18",
    "@types/chrome": "0.2.0",
    "@types/node": "25.9.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/webextension-polyfill": "0.12.5",
    "@vitejs/plugin-react": "6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "husky": "9.1.7",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-bundle-visualizer": "1.2.1",
    "vitest": "4.1.9",
    "web-ext": "10.4.0",
    "webextension-polyfill": "0.12.0"
  }
}

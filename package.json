{
  "name": "aria2-extension",
  "displayName": "Aria2 Integration Extension",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "analyze": "npx vite-bundle-visualizer",
    "build": "tsc && vite build",
    "build:chrome": "tsc && TARGET=CHROME vite build",
    "complete": "pnpm run build && pnpm run package",
    "complete:chrome": "pnpm run build:chrome && pnpm run package",
    "dev": "vite build --mode dev && web-ext run --source-dir ./build/",
    "dev:chrome": "TARGET=CHROME vite build --mode dev && web-ext run --source-dir ./build/ -t chromium",
    "lint": "biome check --write .",
    "package": "web-ext build --config=webext.config.cjs",
    "prepare": "husky",
    "test": "jest",
    "type-check": "tsc --pretty --noEmit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-form": "1.28.5",
    "@tanstack/react-query": "5.91.3",
    "@tanstack/react-router": "1.168.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@jest/globals": "30.3.0",
    "@tanstack/router-plugin": "1.167.2",
    "@types/chrome": "0.1.38",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/webextension-polyfill": "0.12.5",
    "@vitejs/plugin-react": "5.2.0",
    "babel-plugin-react-compiler": "1.0.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "ts-jest": "29.4.6",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-bundle-visualizer": "1.2.1",
    "vite-tsconfig-paths": "6.1.1",
    "web-ext": "10.0.0",
    "webextension-polyfill": "0.12.0"
  }
}
